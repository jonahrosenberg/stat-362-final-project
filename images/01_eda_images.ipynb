   "source": [
    "import os"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "b2c3d4e5",
   "metadata": {},
   "source": [
    "## Image class distribution"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "c4d5e6f7",
   "metadata": {},
   "outputs": [],
   "source": [
    "img_root = '../data/Images'\n",
    "counts = {cls: len(os.listdir(os.path.join(img_root, cls))) for cls in os.listdir(img_root)}\n",
    "total = sum(counts.values())\n",
    "for cls, n in counts.items():\n",
    "    print(f'{cls}: {n} ({n/total:.1%})')"
   ]
  }
